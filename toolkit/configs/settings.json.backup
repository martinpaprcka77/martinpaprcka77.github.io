{
    "menu": {
        "theme": "default",
        "showHeader": true,
        "colorScheme": "cyan"
    },
    "docker": {
        "defaultCommand": "ps",
        "autoRefresh": false
    },
    "system": {
        "checkDisks": true,
        "checkServices": true,
        "checkNetwork": true,
        "checkProcesses": true
    }
}
