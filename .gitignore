# User overrides (not versioned)
profile/core/extra.ps1

# Secrets and environment
toolkit/configs/secrets.*
*.secret
.env

# Local toolkit config — user's saved settings + Save-ToolkitConfig backup.
# The shipped default lives in configs/settings.example.json; Get-ToolkitConfig
# falls back to its hardcoded defaults when this file is absent. Tracking it
# would make `configure`/Save-ToolkitConfig dirty the tree and break the next
# `update.ps1` (git pull --ff-only) / remote-install `git reset --hard`.
toolkit/configs/settings.json
toolkit/configs/settings.json.backup

# Node
node_modules/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/agent-instructions.md
.idea/
*.sublime-*

# Generated
toolkit/scripts/profiles-fragment.json
toolkit/icons/*.png
*.log

# PowerShell Gallery
*.nupkg
.psgallery/

# Tooling metadata
.reasonix/
reasonix.toml
PowerShell/
